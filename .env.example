# ──────────────────────────────────────────────────────────────────────────────
# BindPlane Agent — credenciais de conexão
#
# Como obter esses valores:
#   BindPlane Console → Agents → Install Agent → Docker
#   O snippet de instalação já mostra o comando completo.
# ──────────────────────────────────────────────────────────────────────────────

# Endpoint do servidor BindPlane OP (cloud)
BINDPLANE_ENDPOINT=https://app.bindplane.com

# Chave de instalação — copie do snippet mostrado no console BindPlane
BINDPLANE_SECRET_KEY=your-secret-key-here

# Nome do agente como vai aparecer na UI do BindPlane
BINDPLANE_AGENT_NAME=data-gen-demo-agent

# Labels para organizar/filtrar agentes no BindPlane
BINDPLANE_LABELS=environment=demo,project=data-gen-demo

# ──────────────────────────────────────────────────────────────────────────────
# Sinais de observabilidade — habilita/desabilita geração por tipo
# Valores aceitos: true / false
# ──────────────────────────────────────────────────────────────────────────────
ENABLE_LOGS=true
ENABLE_METRICS=true
ENABLE_TRACES=true

# ──────────────────────────────────────────────────────────────────────────────
# Backends de monitoramento locais (Prometheus, Grafana, Tempo)
# Por padrão desabilitados — habilite quando quiser visualizar dados localmente.
# Obs: o modo standalone (make start-standalone) ignora esses flags e sempre
#      sobe todos os backends, pois são necessários para o pipeline funcionar.
# ──────────────────────────────────────────────────────────────────────────────
ENABLE_PROMETHEUS=false
ENABLE_LOKI=false
ENABLE_TEMPO=false
ENABLE_GRAFANA=false

# ──────────────────────────────────────────────────────────────────────────────
# Gerenciado pelo Makefile — não edite manualmente
# ──────────────────────────────────────────────────────────────────────────────
OTLP_ENDPOINT=bindplane-agent:4317
